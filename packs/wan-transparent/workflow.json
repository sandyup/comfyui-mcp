    {
      "id": 642,
      "type": "Note",
      "pos": [
        21089.276625337516,
        1346.1714260125952
      ],
      "size": [
        1083.2541827723726,
        804.4851696802823
      ],
      "flags": {},
      "order": 13,
      "mode": 4,
      "inputs": [],
      "outputs": [],
      "properties": {
        "ue_properties": {
          "version": "7.4.1",
          "widget_ue_connectable": {},
          "input_ue_unconnectable": {}
        }
      },
      "widgets_values": [
        "\n\n\n\n<---Insert the emotion yoiu want in this format example or use the following examples (only 1 line at at time):\nsurprise: emotion: surprise, eyes blast wide open, eyebrows shoot upward fast, mouth opens fully, head jerks backward sharply, shoulders jump in a sudden flinch, full-body shock reaction\n\nsadness: emotion: sadness, eyes droop heavily, eyelids tremble, eyebrows collapse inward, mouth pulls into a deep frown, head sinks downward slowly, shoulders slump dramatically\n\nremorse: emotion: remorse, eyes avoid contact, eyebrows pinch tight, mouth presses and trembles, head bows deeply, visible chest collapse, hands fidget in guilt\n\nrelief: emotion: relief, eyebrows relax instantly, head tilts back with release, chest expands with strong exhale, eyes close briefly then reopen, shoulders drop with force\n\nrealization: emotion: realization, eyes widen violently then focus, eyebrows shoot up unevenly, mouth forms a strong “oh”, head snaps forward, body freezes in sudden awareness\n\npride: emotion: pride, chest thrusts forward confidently, chin lifts high, bold smirk forms, eyebrows stabilize strongly, head tilts back with dominance, posture straightens\n\noptimism: emotion: optimism, bright wide eyes, eyebrows rise enthusiastically, big hopeful smile, head lifts upward, upper body rises with positive energy\n\nneutral: emotion: neutral, expression steady, minimal motion, natural blinking, relaxed posture, no visible emotional tension\n\nnervousness: emotion: nervousness, rapid eye darts, eyebrows twitch, lips tighten then release, head jitters slightly, shoulders tense upward, hands fidget quickly\n\nlove: emotion: love, eyes soften intensely, eyelids half-close, warm glowing smile, head leans forward gently, expression melts into affection\n\njoy: emotion: joy, wide open smile, eyes squint happily, head lifts upward energetically, shoulders bounce lightly, strong upbeat movement\n\ngrief: emotion: grief, eyebrows pull upward painfully, eyelids tremble, jaw shakes, mouth tightens in sorrow, head drops heavily, shoulders shudder\n\ngratitude: emotion: gratitude, eyes soften deeply, eyebrows rise warmly, sincere smile forms, head dips slightly, hand moves toward chest with appreciation\n\nfear: emotion: fear, eyes burst open, eyebrows yank upward and inward, mouth opens wide in panic, head jolts backward, shoulders tense hard, trembling facial motion\n\nexcitement: emotion: excitement, eyes widen brightly, huge grin, eyebrows bounce up and down, head leans forward quickly, upper body vibrates with energy\n\nembarrassment: emotion: embarrassment, eyes dart away instantly, lips press into awkward smile, head tilts down and sideways, shoulders curl upward, small nervous fidgets\n\ndisgust: emotion: disgust, nose wrinkles sharply, upper lip curls aggressively, eyes narrow hard, head jerks backward fast, full facial recoil\n\ndisapproval: emotion: disapproval, eyebrows lower and pinch, eyes narrow sharply, lips press into a straight harsh line, head tilts back slightly, slow controlled side motion\n\ndisappointment: emotion: disappointment, eyelids drop heavily, eyebrows pull downward, mouth falls into a defeated frown, head sinks forward, shoulders collapse\n\ndesire: emotion: desire, half-lidded intense eyes, slow inhale visible in chest, lips part softly, head leans closer, expression warm and focused\n\ncuriosity: emotion: curiosity, eyebrows lift asymmetrically, eyes widen and track upward, mouth opens slightly, head tilts noticeably to one side, forward lean\n\nconfusion: emotion: confusion, eyebrows twist inward, eyes shift around in uncertainty, mouth opens unevenly, head tilts left then right in quick alternating motions\n\ncaring: emotion: caring, warm soft eyes, gentle empathetic smile, eyebrows lift slightly, head leans forward slowly, posture soft and protective\n\napproval: emotion: approval, confident warm smile, eyebrows lift in agreement, head nods upward once clearly, posture opens and relaxes\n\nannoyance: emotion: annoyance, eyebrows crash downward, nostrils flare, lips tighten hard, head snaps to the side sharply, shoulders tense\n\nanger: emotion: anger, eyes narrow fiercely, eyebrows slam downward, jaw clenches, lips tighten and pull back slightly, head thrusts forward aggressively\n\namusement: emotion: amusement, playful half-grin grows quickly, eyebrows lift, eyes squint in laughter, head tilts back with a chuckle motion, shoulders bounce\n\nadmiration: emotion: admiration, eyes widen softly in awe, eyebrows lift smoothly, warm proud smile builds, head tilts upward and toward subject, expression glows\n"
      ],
      "color": "#432",
      "bgcolor": "#653"
    },
